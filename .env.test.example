# Variáveis de Ambiente para Testes E2E
# 
# Copie este arquivo para .env.test e preencha com suas credenciais de teste
# NUNCA commite o arquivo .env.test com credenciais reais!

# Credenciais de usuário de teste
TEST_USER_EMAIL=seu-email-de-teste@exemplo.com
TEST_USER_PASSWORD=sua-senha-de-teste

# URL base para os testes
# Desenvolvimento local
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Para testar em DEV
# PLAYWRIGHT_BASE_URL=https://luisices-dev.web.app

# Para testar em PRODUÇÃO (use com cuidado!)
# PLAYWRIGHT_BASE_URL=https://seu-site.com
