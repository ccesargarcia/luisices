# Variáveis de Ambiente para Testes E2E
#
# ⚠️ IMPORTANTE: Este é apenas um TEMPLATE!
#
# Para usar:
# 1. Copie este arquivo: cp .env.test.example .env.test
# 2. Preencha com suas credenciais REAIS
# 3. NUNCA commite o arquivo .env.test (ele está no .gitignore)
#
# No CI/CD (GitHub Actions), essas variáveis são injetadas via GitHub Secrets.
# Veja: .github/SECRETS_QUICKSTART.md

# Credenciais de usuário de teste
# Use um usuário DEDICADO para testes, não um usuário real de produção!
TEST_USER_EMAIL=seu-email-de-teste@exemplo.com
TEST_USER_PASSWORD=sua-senha-de-teste

# URL base para os testes
# Desenvolvimento local
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Para testar em DEV (após deploy)
# PLAYWRIGHT_BASE_URL=https://dev.luisices.com.br

# Para testar em PRODUÇÃO (use com MUITO cuidado!)
# PLAYWRIGHT_BASE_URL=https://luisices.com.br
