import { test, expect } from '@playwright/test';

/**
 * Testes CRUD de Clientes
 */

const TEST_USER = {
  email: process.env.TEST_USER_EMAIL || 'teste@exemplo.com',
  password: process.env.TEST_USER_PASSWORD || 'senha123',
};

test.beforeEach(async ({ page }) => {
  await page.goto('/');
  await page.fill('input[type="email"]', TEST_USER.email);
  await page.fill('input[type="password"]', TEST_USER.password);
  await page.click('button[type="submit"]');
  await page.waitForURL('**/dashboard', { timeout: 10000 });
  
  // Navegar para a página de clientes
  await page.goto('/clientes');
  await expect(page.locator('main h1').first()).toContainText(/Clientes/i, { timeout: 10000 });
});

test.describe('Clientes - CRUD', () => {
  const testCustomer = {
    name: `Cliente Teste ${Date.now()}`,
    phone: `(11) 98765-${Math.floor(1000 + Math.random() * 9000)}`,
    email: `teste${Date.now()}@exemplo.com`,
    notes: 'Cliente criado por teste automatizado',
  };

  test('deve criar um novo cliente', async ({ page }) => {
    // Clicar no botão "Novo Cliente"
    const newCustomerButton = page.getByRole('button', { name: /Novo Cliente/i });
    await expect(newCustomerButton).toBeVisible({ timeout: 5000 });
    await newCustomerButton.click();

    // Aguardar dialog abrir
    await expect(page.getByRole('dialog')).toBeVisible({ timeout: 5000 });
    await expect(page.getByText(/Novo Cliente/i).first()).toBeVisible();

    // Preencher formulário
    await page.getByLabel(/Nome.*\*/i).fill(testCustomer.name);
    await page.getByLabel(/Telefone.*\*/i).fill(testCustomer.phone);
    await page.getByLabel(/E-mail/i).fill(testCustomer.email);
    await page.getByLabel(/Observações/i).fill(testCustomer.notes);

    // Salvar
    const saveButton = page.getByRole('button', { name: /Salvar/i });
    await saveButton.click();

    // Aguardar dialog fechar e verificar que cliente foi criado
    await expect(page.getByRole('dialog')).not.toBeVisible({ timeout: 10000 });

    // Buscar pelo cliente criado
    const searchInput = page.getByPlaceholder(/Buscar por nome/i);
    await searchInput.fill(testCustomer.name);

    // Verificar que o cliente aparece na lista
    await expect(page.getByText(testCustomer.name)).toBeVisible({ timeout: 5000 });
  });

  test('deve editar um cliente existente', async ({ page }) => {
    // Primeiro criar um cliente
    const newCustomerButton = page.getByRole('button', { name: /Novo Cliente/i });
    await newCustomerButton.click();
    
    await page.getByLabel(/Nome.*\*/i).fill(testCustomer.name);
    await page.getByLabel(/Telefone.*\*/i).fill(testCustomer.phone);
    await page.getByRole('button', { name: /Salvar/i }).click();
    await expect(page.getByRole('dialog')).not.toBeVisible({ timeout: 10000 });

    // Buscar o cliente
    const searchInput = page.getByPlaceholder(/Buscar cliente/i);
    await searchInput.fill(testCustomer.name);
    await expect(page.getByText(testCustomer.name)).toBeVisible({ timeout: 5000 });

    // Clicar no card do cliente para abrir detalhes
    await page.getByText(testCustomer.name).click();

    // Aguardar e clicar no botão de editar
    const editButton = page.getByRole('button', { name: /Editar/i }).first();
    await expect(editButton).toBeVisible({ timeout: 5000 });
    await editButton.click();

    // Modificar o nome
    const updatedName = `${testCustomer.name} - Editado`;
    const nameInput = page.getByLabel(/Nome.*\*/i);
    await nameInput.clear();
    await nameInput.fill(updatedName);

    // Salvar
    await page.getByRole('button', { name: /Salvar/i }).click();
    await expect(page.getByRole('dialog')).not.toBeVisible({ timeout: 10000 });

    // Verificar que o nome foi atualizado
    await page.reload();
    await searchInput.fill(updatedName);
    await expect(page.getByText(updatedName)).toBeVisible({ timeout: 5000 });
  });

  test('deve excluir um cliente', async ({ page }) => {
    // Primeiro criar um cliente
    const newCustomerButton = page.getByRole('button', { name: /Novo Cliente/i });
    await newCustomerButton.click();
    
    await page.getByLabel(/Nome.*\*/i).fill(testCustomer.name);
    await page.getByLabel(/Telefone.*\*/i).fill(testCustomer.phone);
    await page.getByRole('button', { name: /Salvar/i }).click();
    await expect(page.getByRole('dialog')).not.toBeVisible({ timeout: 10000 });

    // Buscar o cliente
    const searchInput = page.getByPlaceholder(/Buscar cliente/i);
    await searchInput.fill(testCustomer.name);
    await expect(page.getByText(testCustomer.name)).toBeVisible({ timeout: 5000 });

    // Clicar no card do cliente
    await page.getByText(testCustomer.name).click();

    // Clicar no botão de excluir
    const deleteButton = page.getByRole('button', { name: /Excluir/i }).first();
    await expect(deleteButton).toBeVisible({ timeout: 5000 });
    await deleteButton.click();

    // Confirmar exclusão
    const confirmButton = page.getByRole('button', { name: /Confirmar|Excluir/i }).last();
    await expect(confirmButton).toBeVisible({ timeout: 5000 });
    await confirmButton.click();

    // Verificar que o cliente foi removido
    await expect(page.getByRole('dialog')).not.toBeVisible({ timeout: 10000 });
    await page.reload();
    await searchInput.fill(testCustomer.name);
    
    // O cliente não deve mais aparecer na lista
    await expect(page.getByText(testCustomer.name)).not.toBeVisible({ timeout: 3000 });
  });

  test('deve validar campos obrigatórios', async ({ page }) => {
    const newCustomerButton = page.getByRole('button', { name: /Novo Cliente/i });
    await newCustomerButton.click();

    // Tentar salvar sem preencher nada
    const saveButton = page.getByRole('button', { name: /Salvar/i });
    await saveButton.click();

    // O dialog deve continuar aberto (validação impediu o salvamento)
    await expect(page.getByRole('dialog')).toBeVisible({ timeout: 2000 });
  });

  test('deve buscar clientes', async ({ page }) => {
    const searchInput = page.getByPlaceholder(/Buscar por nome/i);
    await expect(searchInput).toBeVisible({ timeout: 5000 });

    // Buscar por algo aleatório
    await searchInput.fill('Cliente Inexistente XYZ123');
    
    // Deve mostrar mensagem de nenhum resultado
    await expect(page.getByText(/Nenhum cliente encontrado/i)).toBeVisible({ timeout: 5000 });
  });

  test('deve exportar clientes para Excel', async ({ page }) => {
    // Verificar que o botão de exportar existe
    const exportButton = page.getByRole('button', { name: /Exportar Excel/i });
    await expect(exportButton).toBeVisible({ timeout: 5000 });

    // Se houver clientes, o botão não deve estar desabilitado
    // (não vamos testar o download em si, apenas a existência da funcionalidade)
  });
});
