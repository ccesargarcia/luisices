rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function para verificar se o usuário é o dono do recurso
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Regras para compartilhamentos
    match /sharedAccess/{accessId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.grantedToUserId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Regras para pedidos (orders)
    // Permite leitura se autenticado (controle de compartilhamento feito no app layer)
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Regras para clientes (customers)
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Regras para orçamentos (quotes)
    match /quotes/{quoteId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Regras para produtos (products)
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Regras para galeria de artes (gallery)
    match /gallery/{itemId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Regras para configurações de usuário (users)
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Perfis de usuário do sistema de permissões
    match /userProfiles/{uid} {
      // Verifica se o solicitante é admin (busca o próprio perfil)
      function isAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
          && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin';
      }

      // Leitura: usuário lê apenas o próprio perfil; admin lê todos
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());

      // Criação: usuário cria o próprio perfil (primeiro acesso automático), ou admin cria para outro
      allow create: if request.auth != null && (request.auth.uid == uid || isAdmin());

      // Atualização: admin pode alterar tudo;
      // usuário comum NÃO pode alterar role, permissions nem active (evita auto-promoção)
      allow update: if request.auth != null && (
        isAdmin()
        || (
          request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.permissions == resource.data.permissions
          && request.resource.data.active == resource.data.active
        )
      );

      // Deleção: somente admins
      allow delete: if isAdmin();
    }
  }
}
